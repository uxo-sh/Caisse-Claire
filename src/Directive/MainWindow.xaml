<Window x:Class="CaisseClaire.Directive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="Resources/logo.png"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        WindowState="Maximized"
        Title="{DynamicResource AppTitle}" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Image Source="pack://application:,,,/Resources/logo.png" Width="40" Height="40" Margin="0,0,10,0" />
                <TextBlock Text="{DynamicResource AppTitle}" FontSize="{DynamicResource TitleFontSize}" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
            
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="btnSettings" Content="{DynamicResource Settings}" Margin="0,0,10,5" Padding="15,5" Click="btnSettings_Click" Background="#FF6C757D" Foreground="White" FontWeight="Bold" />
                <Button x:Name="btnManageCatalog" Content="{DynamicResource ManageCatalog}" Margin="0,0,0,5" Padding="15,5" Click="btnManageCatalog_Click" Background="#FF28A745" Foreground="White" FontWeight="Bold" />
            </WrapPanel>
        </Grid>

        <!-- Left Column: Input Panel -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- Highly Visible Persistent Error Label -->
                <TextBlock x:Name="lblError" Grid.Row="0" FontSize="16" FontWeight="Bold" Foreground="#FFDC3545" TextWrapping="Wrap" Margin="0,0,0,10" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ProductEntry}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                
                <TextBlock Text="{DynamicResource ProductCode}" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5" />
                <TextBox x:Name="txtProductCode" Height="30" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,10" VerticalContentAlignment="Center" KeyDown="txtProductCode_KeyDown" />

                <TextBlock Text="{DynamicResource Quantity}" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5" />
                <TextBox x:Name="txtQuantity" Height="30" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,10" Text="1" VerticalContentAlignment="Center" />

                <Button x:Name="btnAddItem" Content="{DynamicResource AddToCart}" Height="40" FontSize="{DynamicResource GlobalFontSize}" FontWeight="Bold" Background="#FF007ACC" Foreground="White" Click="btnAddItem_Click" Margin="0,0,0,20" />

                <Rectangle Height="1" Fill="LightGray" Margin="0,5,0,15" />

                <TextBlock Text="{DynamicResource CustomProduct}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                <TextBlock Text="{DynamicResource CustomPrice}" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5" />
                <TextBox x:Name="txtCustomPrice" Height="30" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,10" VerticalContentAlignment="Center" />
                <TextBlock Text="{DynamicResource Quantity}" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5" />
                <TextBox x:Name="txtCustomQuantity" Text="1" Height="30" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,10" VerticalContentAlignment="Center" />
                <Button x:Name="btnAddCustom" Content="{DynamicResource AddCustomItem}" Height="40" FontSize="{DynamicResource GlobalFontSize}" FontWeight="Bold" Background="#FF6C757D" Foreground="White" Click="btnAddCustom_Click" Margin="0,0,0,20" />

                <Rectangle Height="1" Fill="LightGray" Margin="0,5,0,15" />

                <TextBlock Text="{DynamicResource Payment}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                <TextBlock Text="{DynamicResource ClientsMoney}" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,5" />
                <TextBox x:Name="txtClientMoney" Height="30" FontSize="{DynamicResource GlobalFontSize}" Margin="0,0,0,10" VerticalContentAlignment="Center" TextChanged="txtClientMoney_TextChanged" />
                </StackPanel>
            </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Column: Cart Panel -->
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" Margin="0,0,0,10" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource ShoppingCart}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,5" />
                    <Button x:Name="btnRemoveItem" Content="{DynamicResource RemoveSelected}" Margin="0,0,0,5" Padding="10,5" Click="btnRemoveItem_Click" Background="#FFDC3545" Foreground="White" />
                </WrapPanel>

                <!-- Shopping Cart Grid -->
                <DataGrid x:Name="dgCart" Grid.Row="1" FontSize="{DynamicResource GlobalFontSize}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,0,0,15" SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding ProductCode}" Width="70" />
                        <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="90" />
                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="70" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Totals -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="{DynamicResource TotalAmount}" FontSize="16" Margin="0,0,10,0" />
                        <TextBlock x:Name="lblTotal" Text="0 MGA" FontSize="16" FontWeight="Bold" Foreground="#FF007ACC" Width="120" TextAlignment="Right" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="{DynamicResource ClientGiven}" FontSize="16" Margin="0,0,10,0" />
                        <TextBlock x:Name="lblClientGiven" Text="0 MGA" FontSize="16" FontWeight="Bold" Width="120" TextAlignment="Right" />
                    </StackPanel>
                    <Rectangle Height="1" Fill="LightGray" Margin="0,5" />
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="{DynamicResource ChangeToReturn}" FontSize="18" FontWeight="Bold" Margin="0,0,10,0" />
                        <TextBlock x:Name="lblChange" Text="0 MGA" FontSize="18" FontWeight="Bold" Foreground="Green" Width="120" TextAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
