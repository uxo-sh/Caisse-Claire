<Window x:Class="CaisseClaire.Directive.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="{DynamicResource SettingsTitle}" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource ThemeLabel}" Width="120" VerticalAlignment="Center" />
            <ComboBox x:Name="cmbTheme" Width="150">
                <ComboBoxItem Content="{DynamicResource LightMode}" />
                <ComboBoxItem Content="{DynamicResource DarkMode}" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource LanguageLabel}" Width="120" VerticalAlignment="Center" />
            <ComboBox x:Name="cmbLanguage" Width="150">
                <ComboBoxItem Content="English" Tag="en" />
                <ComboBoxItem Content="Français" Tag="fr" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource FontScaleLabel}" Width="120" VerticalAlignment="Center" />
            <Slider x:Name="sldFontScale" Width="150" Minimum="0.8" Maximum="1.5" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
            <TextBlock x:Name="lblFontScaleValue" Text="{Binding Value, ElementName=sldFontScale, StringFormat=N1}" Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="lblMessage" Margin="0,0,15,0" Foreground="Green" VerticalAlignment="Center" />
            <Button x:Name="btnSave" Content="{DynamicResource SaveApply}" Width="150" Height="35" Click="btnSave_Click" Background="#FF007ACC" Foreground="White" FontWeight="Bold" />
        </StackPanel>
    </Grid>
</Window>
