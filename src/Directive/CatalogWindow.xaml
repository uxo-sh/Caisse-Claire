<Window x:Class="CaisseClaire.Directive.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="{DynamicResource ManageCatalogTitle}" Height="600" Width="850" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="{DynamicResource ManageCatalogTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,5" />
            <Button x:Name="btnExportPdf" Content="{DynamicResource ExportPdf}" Margin="0,0,10,5" Padding="15,5" Click="btnExportPdf_Click" Background="#FF17A2B8" Foreground="White" FontWeight="Bold" />
            <Button x:Name="btnMarkForDeletion" Content="{DynamicResource MarkForDeletion}" Margin="0,0,10,5" Padding="15,5" Click="btnMarkForDeletion_Click" Background="#FFFFA500" Foreground="White" FontWeight="Bold" />
            <Button x:Name="btnConfirmDeletion" Content="{DynamicResource ConfirmDeletion}" Margin="0,0,10,5" Padding="15,5" Click="btnConfirmDeletion_Click" Background="#FFDC3545" Foreground="White" FontWeight="Bold" Visibility="Collapsed" />
            <Button x:Name="btnSaveChanges" Content="{DynamicResource SaveOrder}" Margin="0,0,0,5" Padding="15,5" Click="btnSaveChanges_Click" Background="#FF28A745" Foreground="White" FontWeight="Bold" />
        </WrapPanel>

        <DataGrid x:Name="dgCatalog" Grid.Row="1" FontSize="{DynamicResource GlobalFontSize}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,15"
                  dd:DragDrop.IsDragSource="True"
                  dd:DragDrop.IsDropTarget="True"
                  dd:DragDrop.UseDefaultDragAdorner="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                            <Setter Property="Background" Value="#FFFFCCCC" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource CodeColumn}" Binding="{Binding Code}" Width="80" />
                <DataGridTextColumn Header="{DynamicResource NameColumn}" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource PriceColumn}" Binding="{Binding Price}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="100">
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource NewItemName}" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center" Margin="0,0,5,5" />
                    <TextBox x:Name="txtAddName" FontSize="{DynamicResource GlobalFontSize}" Width="150" Height="30" Margin="0,0,15,5" VerticalContentAlignment="Center" />
                    
                    <TextBlock Text="{DynamicResource PriceLabel}" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center" Margin="0,0,5,5" />
                    <TextBox x:Name="txtAddPrice" FontSize="{DynamicResource GlobalFontSize}" Width="80" Height="30" Margin="0,0,15,5" VerticalContentAlignment="Center" />
                    
                    <Button x:Name="btnAddProduct" Content="{DynamicResource AddToCatalog}" Padding="10,5" Margin="0,0,15,5" Click="btnAddProduct_Click" Background="#FF007ACC" Foreground="White" FontWeight="Bold" />
                    <TextBlock x:Name="lblMessage" Margin="0,0,0,5" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                </WrapPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
