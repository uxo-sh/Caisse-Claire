<Window x:Class="CaisseClaire.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CaisseClaire — Caisse Enregistreuse"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" Padding="20,0">
            <Grid>
                <TextBlock Text="🛒 CaisseClaire"
                           VerticalAlignment="Center"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#CDD6F4"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Caisse Enregistreuse Intelligente"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="13"
                           Foreground="#6C7086"
                           FontFamily="Segoe UI"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Products Panel -->
            <Border Grid.Column="0" Background="#313244" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📦 Produits"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,12"/>

                    <!-- Search Bar -->
                    <TextBox Grid.Row="1"
                             x:Name="SearchBox"
                             Text="" 
                             Background="#45475A"
                             Foreground="#CDD6F4"
                             BorderBrush="#585B70"
                             Padding="10,8"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <!-- Product List -->
                    <ListView Grid.Row="2"
                              x:Name="ProductListView"
                              Background="Transparent"
                              BorderBrush="Transparent"
                              Foreground="#CDD6F4"
                              FontSize="14">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#45475A" CornerRadius="8" Padding="12,8" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#CDD6F4"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='{}{0:C}'}" Foreground="#A6E3A1" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Cart / Transaction Panel -->
            <Border Grid.Column="2" Background="#313244" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🧾 Panier"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#CDD6F4" Margin="0,0,0,12"/>

                    <!-- Cart Items -->
                    <ListBox Grid.Row="1"
                             x:Name="CartListBox"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             Foreground="#CDD6F4"/>

                    <!-- Total -->
                    <Border Grid.Row="2" Background="#45475A" CornerRadius="8" Padding="12" Margin="0,12,0,8">
                        <Grid>
                            <TextBlock Text="Total:" FontSize="16" FontWeight="Bold" Foreground="#CDD6F4"/>
                            <TextBlock x:Name="TotalText"
                                       Text="0,00 €"
                                       HorizontalAlignment="Right"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#F9E2AF"/>
                        </Grid>
                    </Border>

                    <!-- Checkout Button -->
                    <Button Grid.Row="3"
                            x:Name="CheckoutButton"
                            Content="💳 Valider la transaction"
                            Background="#A6E3A1"
                            Foreground="#1E1E2E"
                            FontSize="15" FontWeight="Bold"
                            Padding="12,10"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#181825" Padding="20,0">
            <TextBlock x:Name="StatusText"
                       Text="Prêt"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#6C7086"/>
        </Border>
    </Grid>
</Window>
